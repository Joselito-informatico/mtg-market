// Schema de TCG Market — fuente única de verdad para la DB

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_DIRECT_URL")
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum Plan {
  FREE
  PREMIUM
}

enum Condition {
  MINT
  NEAR_MINT
  EXCELLENT
  GOOD
  LIGHT_PLAYED
  PLAYED
  POOR
}

enum Language {
  EN
  ES
  PT
  DE
  FR
  IT
  JA
  KO
  RU
  ZHS
  ZHT
  HE
  LA
  GRC
  AR
  SA
  PH
}

enum ListingStatus {
  ACTIVE
  INACTIVE
  SOLD
}

// ─────────────────────────────────────────────
// User
// ─────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  username  String   @unique
  name      String?
  phone     String?
  lgs       String?  // Local Game Store preferida
  plan      Plan     @default(FREE)
  isPrivate Boolean  @default(false)
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions    Session[]
  collection  Collection[]
  decks       Deck[]
  listings    Listing[]
  feedbacks   Feedback[]

  @@index([username])
  @@index([email])
}

// ─────────────────────────────────────────────
// Session (Better Auth)
// ─────────────────────────────────────────────

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

// ─────────────────────────────────────────────
// Collection
// ─────────────────────────────────────────────

model Collection {
  id          String    @id @default(cuid())
  userId      String
  scryfallId  String    // UUID de Scryfall — NUNCA texto ni imagen
  condition   Condition @default(NEAR_MINT)
  quantity    Int       @default(1)
  foil        Boolean   @default(false)
  language    Language  @default(EN)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  listings Listing[]

  @@unique([userId, scryfallId, condition, foil, language])
  @@index([userId])
  @@index([scryfallId])
}

// ─────────────────────────────────────────────
// Deck
// ─────────────────────────────────────────────

model Deck {
  id          String   @id @default(cuid())
  userId      String?  // Nullable para mazos anónimos
  name        String
  format      String?
  description String?
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user  User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  cards DeckCard[]

  @@index([userId])
}

// ─────────────────────────────────────────────
// DeckCard
// ─────────────────────────────────────────────

model DeckCard {
  id          String  @id @default(cuid())
  deckId      String
  scryfallId  String  // UUID de Scryfall — NUNCA texto ni imagen
  quantity    Int     @default(1)
  isCommander Boolean @default(false)
  isSideboard Boolean @default(false)

  deck Deck @relation(fields: [deckId], references: [id], onDelete: Cascade)

  @@unique([deckId, scryfallId, isCommander, isSideboard])
  @@index([deckId])
  @@index([scryfallId])
}

// ─────────────────────────────────────────────
// Listing (Marketplace)
// ─────────────────────────────────────────────

model Listing {
  id           String        @id @default(cuid())
  userId       String
  collectionId String
  priceUsd     Decimal       @db.Decimal(10, 2)
  status       ListingStatus @default(ACTIVE)
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([collectionId])
  @@index([status])
}

// ─────────────────────────────────────────────
// Feedback
// ─────────────────────────────────────────────

model Feedback {
  id        String   @id @default(cuid())
  userId    String?
  message   String
  category  String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
}